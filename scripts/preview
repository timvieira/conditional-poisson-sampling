#!/usr/bin/env python3
"""Preview the blog post with auto-rebuild on file changes."""

import sys
from pathlib import Path

BLOG_DIR = Path.home() / "projects/blog/main"
sys.path.insert(0, str(BLOG_DIR))

import build, postdev

build.CONTENT_DIR = Path("content")
build.OUTPUT_DIR = Path("output")
build.TEMPLATE_DIR = BLOG_DIR
build.STATIC_DIRS = []

build.build()
postdev.watch(["content", BLOG_DIR / "template.html"], build.build)
postdev.serve("output", port=8000)
