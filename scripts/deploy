#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "Building..."
python3 -c "
import re, sys; from pathlib import Path
sys.path.insert(0, str(Path.home() / 'projects/blog/main'))
import build
build.CONTENT_DIR = Path('content')
build.OUTPUT_DIR = Path('output')
build.TEMPLATE_DIR = Path.home() / 'projects/blog/main'
build.STATIC_DIRS = []
build.build()

# Rewrite CSS references to point to the central blog
for html in Path('output').rglob('*.html'):
    text = html.read_text()
    fixed = re.sub(
        r'href=\"[^\"]*?/css/blog\.css\"',
        'href=\"https://timvieira.github.io/blog/css/blog.css\"',
        text,
    )
    if fixed != text:
        html.write_text(fixed)
"

echo "Committing output..."
git add output/
if git diff --cached --quiet; then
    echo "No changes to deploy."
    exit 0
fi
git commit -m "Rebuild output for GitHub Pages"
git push
echo "Deployed to https://timvieira.github.io/conditional-poisson-sampling/"
